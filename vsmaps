#!/usr/bin/env bash
#
# vsmaps - CLI tool for managing vuSmartMaps local environment
#
# Usage:
#   ./vsmaps install    - Full install from scratch
#   ./vsmaps reset      - Tear down and reinstall
#   ./vsmaps upgrade    - Upgrade components (selective or full)
#   ./vsmaps load-data  - Load dummy data fixtures
#   ./vsmaps clear-data - Clear all test data
#   ./vsmaps status     - Show environment status
#

set -euo pipefail

# ─── Global Flags ────────────────────────────────────────────────────────────

FORCE_YES=false

# ─── Configuration ───────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NAMESPACE="vsmaps"
KIND_CLUSTER_NAME="kind"
KIND_CONFIG="${SCRIPT_DIR}/kind-config.yaml"
CLUSTER_SETUP_DIR="${SCRIPT_DIR}/cluster-setup"
HELM_CHARTS_DIR="${SCRIPT_DIR}/helm-charts"
IMAGES_DIR="${SCRIPT_DIR}/images"
FIXTURES_DIR="${SCRIPT_DIR}/fixtures"
DATA_ROOT="/data1"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Helm chart deployment order with their paths relative to helm-charts/
# Format: "release_name:chart_path:timeout"
HELM_DEPLOY_ORDER=(
    "postgresql:postgresql:5m"
    "keycloak:keycloak:5m"
    "denver:denver:5m"
    "minio-operator:minio/operator:5m"
    "minio-tenant:minio/tenant:5m"
    "orchestrator:orchestrator:5m"
    "kafka-cluster:kafka-cluster:5m"
    "ch-operator:clickhouse/ch-operator:5m"
    "ch-keeper:clickhouse/ch-keeper:5m"
    "ch-database:clickhouse/ch-database:15m"
    "telegraf-vumsart:telegraf/vusmart:5m"
    "telegraf-infra:telegraf/infra:5m"
    "nairobi:nairobi:5m"
    "traefik:traefik:5m"
    "redis:redis:5m"
    "docs:docs:5m"
    "vublock-store:vublock-store:5m"
    "vunodes:vunodes:5m"
    "post-job:post-job:15m"
)

# Persistent storage directories to create
STORAGE_DIRS=(
    "${DATA_ROOT}/postgresql"
    "${DATA_ROOT}/minio"
    "${DATA_ROOT}/zookeeper-log"
    "${DATA_ROOT}/kafka_zookeeper_dir"
    "${DATA_ROOT}/kafka_dir"
    "${DATA_ROOT}/clickhouse"
    "${DATA_ROOT}/clickhouse-warm"
    "${DATA_ROOT}/clickhouse-keeper"
)

# ─── Helper Functions ────────────────────────────────────────────────────────

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

log_step() {
    echo -e "\n${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}  $1${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
}

elapsed_time() {
    local start=$1
    local end
    end=$(date +%s)
    local diff=$((end - start))
    local mins=$((diff / 60))
    local secs=$((diff % 60))
    echo "${mins}m ${secs}s"
}

check_prerequisites() {
    log_step "Checking prerequisites"

    local missing=0

    if ! command -v docker &>/dev/null; then
        log_error "Docker is not installed"
        missing=1
    else
        log_success "Docker found: $(docker --version)"
    fi

    if ! command -v kubectl &>/dev/null; then
        log_error "kubectl is not installed"
        missing=1
    else
        log_success "kubectl found: $(kubectl version --client --short 2>/dev/null || kubectl version --client 2>/dev/null | head -1)"
    fi

    if ! command -v kind &>/dev/null; then
        log_error "Kind is not installed"
        missing=1
    else
        log_success "Kind found: $(kind version)"
    fi

    if ! command -v helm &>/dev/null; then
        log_error "Helm is not installed"
        missing=1
    else
        log_success "Helm found: $(helm version --short)"
    fi

    if [ $missing -eq 1 ]; then
        log_error "Missing prerequisites. Please install them and try again."
        exit 1
    fi
}

# ─── Kind Cluster Management ────────────────────────────────────────────────

create_kind_cluster() {
    log_step "Creating Kind cluster"

    if kind get clusters 2>/dev/null | grep -q "^${KIND_CLUSTER_NAME}$"; then
        log_warn "Kind cluster '${KIND_CLUSTER_NAME}' already exists"
        return 0
    fi

    if [ ! -f "${KIND_CONFIG}" ]; then
        log_error "kind-config.yaml not found at ${KIND_CONFIG}"
        exit 1
    fi

    kind create cluster --config "${KIND_CONFIG}"
    log_success "Kind cluster created"

    # Verify node is ready
    kubectl wait --for=condition=Ready node --all --timeout=120s
    log_success "Cluster node is ready"
}

delete_kind_cluster() {
    log_step "Deleting Kind cluster"

    if kind get clusters 2>/dev/null | grep -q "^${KIND_CLUSTER_NAME}$"; then
        kind delete cluster --name "${KIND_CLUSTER_NAME}"
        log_success "Kind cluster deleted"
    else
        log_warn "No Kind cluster found to delete"
    fi
}

# ─── Cluster Pre-requisites ─────────────────────────────────────────────────

apply_cluster_prerequisites() {
    log_step "Applying cluster pre-requisites"

    # Create namespace
    if kubectl get namespace "${NAMESPACE}" &>/dev/null; then
        log_warn "Namespace '${NAMESPACE}' already exists"
    else
        kubectl create namespace "${NAMESPACE}"
        log_success "Namespace '${NAMESPACE}' created"
    fi

    # Apply cluster-setup manifests
    for manifest in local-storage-class.yaml pipeline-sa.yaml role_rolebinding.yaml; do
        if [ -f "${CLUSTER_SETUP_DIR}/${manifest}" ]; then
            kubectl apply -f "${CLUSTER_SETUP_DIR}/${manifest}" -n "${NAMESPACE}"
            log_success "Applied ${manifest}"
        else
            log_warn "${manifest} not found, skipping"
        fi
    done
}

# ─── Docker Image Loading ───────────────────────────────────────────────────

load_images() {
    log_step "Loading Docker images into Kind"

    if [ ! -d "${IMAGES_DIR}" ]; then
        log_error "Images directory not found at ${IMAGES_DIR}"
        log_error "Please extract vuSmartMapsLocal-2.16.tar.gz first"
        exit 1
    fi

    local gz_count
    gz_count=$(find "${IMAGES_DIR}" -name "*.tar.gz" | wc -l)

    if [ "$gz_count" -gt 0 ]; then
        log_info "Decompressing ${gz_count} image archives..."
        cd "${IMAGES_DIR}"
        gunzip -f *.tar.gz 2>/dev/null || true
        cd "${SCRIPT_DIR}"
        log_success "Decompressed image archives"
    fi

    local tar_files
    tar_files=$(find "${IMAGES_DIR}" -name "*.tar" | sort)
    local total
    total=$(echo "$tar_files" | wc -l)
    local count=0

    for img in $tar_files; do
        count=$((count + 1))
        local basename
        basename=$(basename "$img")
        log_info "[${count}/${total}] Loading ${basename}..."
        if kind load image-archive "$img" 2>/dev/null; then
            log_success "Loaded ${basename}"
        else
            log_warn "Failed to load ${basename}, continuing..."
        fi
    done

    log_success "Image loading complete (${total} images)"
}

# ─── Persistent Storage ─────────────────────────────────────────────────────

create_storage_directories() {
    log_step "Creating persistent storage directories"

    local kind_container
    kind_container=$(docker ps --filter "name=kind-control-plane" --format '{{.Names}}' | head -1)

    if [ -z "$kind_container" ]; then
        log_error "Kind control-plane container not found"
        exit 1
    fi

    for dir in "${STORAGE_DIRS[@]}"; do
        docker exec "$kind_container" mkdir -p "$dir"
        log_success "Created ${dir}"
    done

    # PostgreSQL needs specific ownership
    docker exec "$kind_container" chown -R 1001:1000 "${DATA_ROOT}/postgresql"
    log_success "Set ownership for PostgreSQL directory"
}

cleanup_storage_directories() {
    log_step "Cleaning up persistent storage directories"

    local kind_container
    kind_container=$(docker ps --filter "name=kind-control-plane" --format '{{.Names}}' | head -1)

    if [ -n "$kind_container" ]; then
        for dir in "${STORAGE_DIRS[@]}"; do
            docker exec "$kind_container" rm -rf "$dir" 2>/dev/null || true
            log_success "Removed ${dir}"
        done
    else
        log_warn "Kind container not running, skipping storage cleanup"
    fi
}

# ─── Helm Chart Deployment ──────────────────────────────────────────────────

wait_for_pods_ready() {
    local release=$1
    local timeout=${2:-300}
    local namespace=$3

    log_info "Waiting for ${release} pods to be ready (timeout: ${timeout}s)..."

    local end_time=$(($(date +%s) + timeout))

    while [ "$(date +%s)" -lt "$end_time" ]; do
        local not_ready
        not_ready=$(kubectl get pods -n "${namespace}" -l "app.kubernetes.io/instance=${release}" \
            --no-headers 2>/dev/null | awk '!/Running|Completed/{c++} END{print c+0}')

        # Also check for pods with the release name directly (some charts don't use standard labels)
        local not_ready2
        not_ready2=$(kubectl get pods -n "${namespace}" --no-headers 2>/dev/null | \
            awk -v rel="^${release}" '$0 ~ rel && !/Running|Completed/{c++} END{print c+0}')

        if [ "$not_ready" -eq 0 ] && [ "$not_ready2" -eq 0 ]; then
            return 0
        fi

        sleep 5
    done

    log_warn "Timeout waiting for ${release} pods. Continuing anyway..."
    return 0
}

deploy_helm_chart() {
    local release=$1
    local chart_path=$2
    local timeout=$3

    local full_chart_path="${HELM_CHARTS_DIR}/${chart_path}"

    if [ ! -d "${full_chart_path}" ]; then
        log_error "Chart not found: ${full_chart_path}"
        return 1
    fi

    # Check if already installed
    if helm status "${release}" -n "${NAMESPACE}" &>/dev/null; then
        log_warn "Release '${release}' already installed, skipping"
        return 0
    fi

    log_info "Installing ${release} from ${chart_path} (timeout: ${timeout})..."

    if helm install "${release}" "${full_chart_path}" -n "${NAMESPACE}" --timeout="${timeout}" 2>&1; then
        log_success "Installed ${release}"
    else
        log_error "Failed to install ${release}"
        return 1
    fi

    # Wait for pods to be ready before proceeding
    local timeout_secs
    timeout_secs=$(( ${timeout%m} * 60 ))
    wait_for_pods_ready "${release}" "${timeout_secs}" "${NAMESPACE}"
}

deploy_all_helm_charts() {
    log_step "Deploying Helm charts"

    local total=${#HELM_DEPLOY_ORDER[@]}
    local count=0

    for entry in "${HELM_DEPLOY_ORDER[@]}"; do
        IFS=':' read -r release chart_path timeout <<< "$entry"
        count=$((count + 1))

        echo -e "\n${YELLOW}[${count}/${total}]${NC} Deploying ${release}..."
        if ! deploy_helm_chart "${release}" "${chart_path}" "${timeout}"; then
            log_warn "Failed to deploy ${release}, continuing with remaining charts..."
        fi
    done

    log_success "All Helm charts deployed"
}

# ─── Install Command ────────────────────────────────────────────────────────

cmd_install() {
    local start_time
    start_time=$(date +%s)

    echo -e "\n${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         vuSmartMaps Local Environment - Install             ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}\n"

    check_prerequisites
    create_kind_cluster
    apply_cluster_prerequisites
    load_images
    create_storage_directories
    deploy_all_helm_charts

    log_step "Installation Complete!"
    echo -e "  Total time: ${GREEN}$(elapsed_time $start_time)${NC}"
    echo -e "  Access UI:  ${GREEN}https://localhost/vui${NC}"
    echo -e "  Login:      ${GREEN}vunetadmin / Qwerty@123${NC}"
    echo ""
}

# ─── Reset Command ──────────────────────────────────────────────────────────

cmd_reset() {
    local start_time
    start_time=$(date +%s)

    echo -e "\n${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         vuSmartMaps Local Environment - Reset               ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}\n"

    log_warn "This will destroy the existing environment and reinstall from scratch."
    if [ "$FORCE_YES" != true ]; then
        read -p "Are you sure? (y/N): " confirm
        if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
            log_info "Reset cancelled."
            exit 0
        fi
    fi

    delete_kind_cluster
    cleanup_storage_directories
    cmd_install

    log_step "Reset Complete!"
    echo -e "  Total time: ${GREEN}$(elapsed_time $start_time)${NC}"
}

# ─── Upgrade Command ────────────────────────────────────────────────────────

cmd_upgrade() {
    local component="${1:-}"

    echo -e "\n${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         vuSmartMaps Local Environment - Upgrade             ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}\n"

    if [ -z "$component" ]; then
        # Full upgrade - upgrade all components
        log_info "Performing full upgrade of all components..."

        # Reload images if images directory exists
        if [ -d "${IMAGES_DIR}" ]; then
            load_images
        fi

        for entry in "${HELM_DEPLOY_ORDER[@]}"; do
            IFS=':' read -r release chart_path timeout <<< "$entry"
            local full_chart_path="${HELM_CHARTS_DIR}/${chart_path}"

            if helm status "${release}" -n "${NAMESPACE}" &>/dev/null; then
                log_info "Upgrading ${release}..."
                helm upgrade "${release}" "${full_chart_path}" -n "${NAMESPACE}" --timeout="${timeout}"
                log_success "Upgraded ${release}"
            else
                log_info "Installing ${release} (not previously installed)..."
                deploy_helm_chart "${release}" "${chart_path}" "${timeout}"
            fi
        done

        log_success "Full upgrade complete"
    else
        # Selective upgrade - find and upgrade the specified component
        local found=0
        for entry in "${HELM_DEPLOY_ORDER[@]}"; do
            IFS=':' read -r release chart_path timeout <<< "$entry"

            if [ "${release}" = "${component}" ]; then
                found=1
                local full_chart_path="${HELM_CHARTS_DIR}/${chart_path}"

                # Reload images for this component if available
                if [ -d "${IMAGES_DIR}" ]; then
                    log_info "Checking for updated images..."
                    local tar_files
                    tar_files=$(find "${IMAGES_DIR}" -name "*.tar" 2>/dev/null || true)
                    for img in $tar_files; do
                        kind load image-archive "$img" 2>/dev/null || true
                    done
                fi

                if helm status "${release}" -n "${NAMESPACE}" &>/dev/null; then
                    log_info "Upgrading ${release}..."
                    helm upgrade "${release}" "${full_chart_path}" -n "${NAMESPACE}" --timeout="${timeout}"
                    log_success "Upgraded ${release}"
                else
                    log_info "Installing ${release} (not previously installed)..."
                    deploy_helm_chart "${release}" "${chart_path}" "${timeout}"
                fi
                break
            fi
        done

        if [ "$found" -eq 0 ]; then
            log_error "Unknown component: ${component}"
            echo ""
            echo "Available components:"
            for entry in "${HELM_DEPLOY_ORDER[@]}"; do
                IFS=':' read -r release _ _ <<< "$entry"
                echo "  - ${release}"
            done
            exit 1
        fi
    fi
}

# ─── Load/Clear Data Commands ───────────────────────────────────────────────

cmd_load_data() {
    echo -e "\n${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         vuSmartMaps Local Environment - Load Test Data      ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}\n"

    if [ ! -d "${FIXTURES_DIR}" ] || [ -z "$(ls -A "${FIXTURES_DIR}" 2>/dev/null | grep -v .gitkeep)" ]; then
        log_warn "No data fixtures found in ${FIXTURES_DIR}"
        log_info "Add fixture files to the fixtures/ directory to use this command."
        exit 0
    fi

    # Load PostgreSQL fixtures
    if ls "${FIXTURES_DIR}"/postgresql_*.sql &>/dev/null; then
        log_info "Loading PostgreSQL fixtures..."
        local pg_pod
        pg_pod=$(kubectl get pods -n "${NAMESPACE}" -l "app.kubernetes.io/name=postgresql" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
        if [ -n "$pg_pod" ]; then
            for f in "${FIXTURES_DIR}"/postgresql_*.sql; do
                local fname
                fname=$(basename "$f")
                log_info "  Loading ${fname}..."
                kubectl cp "$f" "${NAMESPACE}/${pg_pod}:/tmp/${fname}"
                kubectl exec -n "${NAMESPACE}" "${pg_pod}" -- bash -c \
                    "PGPASSWORD=vusmart psql -U vusmart -d multicore -f /tmp/${fname}" 2>&1 || \
                kubectl exec -n "${NAMESPACE}" "${pg_pod}" -- bash -c \
                    "PGPASSWORD=\$POSTGRES_PASSWORD psql -U postgres -d multicore -f /tmp/${fname}" 2>&1
                log_success "  Loaded ${fname}"
            done
        else
            log_warn "PostgreSQL pod not found, skipping PostgreSQL fixtures"
        fi
    fi

    # Load ClickHouse fixtures
    if ls "${FIXTURES_DIR}"/clickhouse_*.sql &>/dev/null; then
        log_info "Loading ClickHouse fixtures..."
        local ch_pod
        ch_pod=$(kubectl get pods -n "${NAMESPACE}" -l "clickhouse.altinity.com/app=chop" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
        if [ -n "$ch_pod" ]; then
            for f in "${FIXTURES_DIR}"/clickhouse_*.sql; do
                local fname
                fname=$(basename "$f")
                log_info "  Loading ${fname}..."
                kubectl cp "$f" "${NAMESPACE}/${ch_pod}:/tmp/${fname}" -c clickhouse
                kubectl exec -n "${NAMESPACE}" "${ch_pod}" -c clickhouse -- \
                    clickhouse-client --user vusmartmanager --password 'Vunet#1234' \
                    --multiquery < "$f" 2>/dev/null || \
                kubectl exec -n "${NAMESPACE}" "${ch_pod}" -c clickhouse -- bash -c \
                    "clickhouse-client --user vusmartmanager --password 'Vunet#1234' < /tmp/${fname}"
                log_success "  Loaded ${fname}"
            done
        else
            log_warn "ClickHouse pod not found, skipping ClickHouse fixtures"
        fi
    fi

    # Load Kafka fixtures (topic data via kafka-console-producer)
    if ls "${FIXTURES_DIR}"/kafka_*.json &>/dev/null; then
        log_info "Loading Kafka fixtures..."
        local kafka_pod
        kafka_pod=$(kubectl get pods -n "${NAMESPACE}" -l "app=cp-kafka" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
        if [ -n "$kafka_pod" ]; then
            for f in "${FIXTURES_DIR}"/kafka_*.json; do
                local fname topic
                fname=$(basename "$f")
                topic=$(echo "$fname" | sed 's/^kafka_//;s/\.json$//')
                log_info "  Loading ${fname} into topic ${topic}..."
                kubectl cp "$f" "${NAMESPACE}/${kafka_pod}:/tmp/${fname}"
                kubectl exec -n "${NAMESPACE}" "${kafka_pod}" -- bash -c \
                    "cat /tmp/${fname} | kafka-console-producer --broker-list localhost:9092 --topic ${topic}"
                log_success "  Loaded ${fname}"
            done
        else
            log_warn "Kafka pod not found, skipping Kafka fixtures"
        fi
    fi

    log_success "Test data loading complete"
}

cmd_clear_data() {
    echo -e "\n${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         vuSmartMaps Local Environment - Clear Test Data     ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}\n"

    log_warn "This will clear all test data from ClickHouse, PostgreSQL, and Kafka."
    if [ "$FORCE_YES" != true ]; then
        read -p "Are you sure? (y/N): " confirm
        if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
            log_info "Clear cancelled."
            exit 0
        fi
    fi

    # Clear PostgreSQL fixture data
    local pg_pod
    pg_pod=$(kubectl get pods -n "${NAMESPACE}" -l "app.kubernetes.io/name=postgresql" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
    if [ -n "$pg_pod" ]; then
        log_info "Clearing PostgreSQL fixture data..."
        if ls "${FIXTURES_DIR}"/postgresql_*.sql &>/dev/null; then
            for f in "${FIXTURES_DIR}"/postgresql_*.sql; do
                local tables
                tables=$(grep -ioP '(?<=INSERT INTO\s)\S+' "$f" | sort -u || true)
                for table in $tables; do
                    kubectl exec -n "${NAMESPACE}" "${pg_pod}" -- \
                        bash -c "PGPASSWORD=vusmart psql -U vusmart -d multicore -c 'DELETE FROM ${table} WHERE true;'" 2>/dev/null || true
                    log_success "  Cleared ${table}"
                done
            done
        fi
        log_success "PostgreSQL data cleared"
    else
        log_warn "PostgreSQL pod not found, skipping"
    fi

    # Clear ClickHouse fixture data
    local ch_pod
    ch_pod=$(kubectl get pods -n "${NAMESPACE}" -l "clickhouse.altinity.com/app=chop" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
    if [ -n "$ch_pod" ]; then
        log_info "Clearing ClickHouse fixture data..."
        if ls "${FIXTURES_DIR}"/clickhouse_*.sql &>/dev/null; then
            for f in "${FIXTURES_DIR}"/clickhouse_*.sql; do
                local table
                table=$(grep -ioP '(?<=INSERT INTO\s)\S+' "$f" | head -1 || true)
                if [ -n "$table" ]; then
                    kubectl exec -n "${NAMESPACE}" "${ch_pod}" -c clickhouse -- \
                        clickhouse-client --user vusmartmanager --password 'Vunet#1234' \
                        --query "TRUNCATE TABLE IF EXISTS ${table}" 2>/dev/null || true
                    log_success "  Cleared ${table}"
                fi
            done
        fi
        log_success "ClickHouse data cleared"
    else
        log_warn "ClickHouse pod not found, skipping"
    fi

    log_success "Test data clearing complete"
}

# ─── Status Command ─────────────────────────────────────────────────────────

cmd_status() {
    echo -e "\n${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║         vuSmartMaps Local Environment - Status              ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}\n"

    # Check Kind cluster
    if kind get clusters 2>/dev/null | grep -q "^${KIND_CLUSTER_NAME}$"; then
        log_success "Kind cluster: Running"
    else
        log_error "Kind cluster: Not running"
        return 0
    fi

    # Check node
    echo ""
    log_info "Cluster nodes:"
    kubectl get nodes -o wide 2>/dev/null || true

    # Check pods
    echo ""
    log_info "Pods in ${NAMESPACE} namespace:"
    kubectl get pods -n "${NAMESPACE}" -o wide 2>/dev/null || true

    # Summary
    echo ""
    local total running completed failed other
    local pod_lines
    pod_lines=$(kubectl get pods -n "${NAMESPACE}" --no-headers 2>/dev/null || true)
    total=$(echo "$pod_lines" | awk 'NF{c++} END{print c+0}')
    running=$(echo "$pod_lines" | awk '/Running/{c++} END{print c+0}')
    completed=$(echo "$pod_lines" | awk '/Completed/{c++} END{print c+0}')
    failed=$(echo "$pod_lines" | awk '/Error|CrashLoopBackOff|ImagePullBackOff/{c++} END{print c+0}')
    other=$((total - running - completed - failed))

    echo -e "  ${BLUE}Total pods:${NC}     ${total}"
    echo -e "  ${GREEN}Running:${NC}        ${running}"
    echo -e "  ${GREEN}Completed:${NC}      ${completed}"
    echo -e "  ${RED}Failed:${NC}         ${failed}"
    if [ "$other" -gt 0 ]; then
        echo -e "  ${YELLOW}Other:${NC}          ${other}"
    fi

    # Helm releases
    echo ""
    log_info "Helm releases:"
    helm list -n "${NAMESPACE}" 2>/dev/null || true
}

# ─── Main ────────────────────────────────────────────────────────────────────

usage() {
    echo -e "${CYAN}vuSmartMaps Local Environment CLI${NC}"
    echo ""
    echo "Usage: $(basename "$0") [--yes] <command> [options]"
    echo ""
    echo "Commands:"
    echo "  install              Install the full vuSmartMaps local environment"
    echo "  reset                Tear down and reinstall from scratch"
    echo "  upgrade [component]  Upgrade all components, or a specific one"
    echo "  load-data            Load dummy data fixtures into the environment"
    echo "  clear-data           Clear all test data from the environment"
    echo "  status               Show current environment status"
    echo ""
    echo "Flags:"
    echo "  -y, --yes            Skip confirmation prompts"
    echo ""
    echo "Components for selective upgrade:"
    for entry in "${HELM_DEPLOY_ORDER[@]}"; do
        IFS=':' read -r release _ _ <<< "$entry"
        echo "  - ${release}"
    done
    echo ""
    echo "Examples:"
    echo "  $(basename "$0") install"
    echo "  $(basename "$0") upgrade nairobi"
    echo "  $(basename "$0") reset"
    echo "  $(basename "$0") load-data"
    echo "  $(basename "$0") status"
}

main() {
    # Parse global flags
    local args=()
    for arg in "$@"; do
        case "$arg" in
            -y|--yes)
                FORCE_YES=true
                ;;
            *)
                args+=("$arg")
                ;;
        esac
    done

    local command="${args[0]:-}"
    local remaining=()
    if [ ${#args[@]} -gt 1 ]; then
        remaining=("${args[@]:1}")
    fi

    case "$command" in
        install)
            cmd_install "${remaining[@]}"
            ;;
        reset)
            cmd_reset "${remaining[@]}"
            ;;
        upgrade)
            cmd_upgrade "${remaining[@]}"
            ;;
        load-data)
            cmd_load_data "${remaining[@]}"
            ;;
        clear-data)
            cmd_clear_data "${remaining[@]}"
            ;;
        status)
            cmd_status "${remaining[@]}"
            ;;
        -h|--help|help|"")
            usage
            ;;
        *)
            log_error "Unknown command: ${command}"
            echo ""
            usage
            exit 1
            ;;
    esac
}

main "$@"
